# Dependencies
node_modules/

# Source mesh files (binary game assets, large)
source-meshes/

# Map data (generated, large binary files)
public/map-data/textures/
# heightmap .bin files ARE committed (64 MB, needed for terrain)
public/map-data/meshes/*.glb
# entities/*.json, entity-index.json, mesh-map.json, mesh-list.json ARE committed

# Runtime browser libs (generated by npm script, not committed)
public/lib/
public/repo-clips/

# Python
__pycache__/
*.pyc

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/

# Local temporary browser/test artifacts
tmp/

# === Generated / runtime artifacts ===
log/
*.log
analyze-output.json
verify-output.json
tmp-*.json
.tmp_*

# === Extracted caches (regenerable from PAK files) ===
cache-extraction/
tools/pss-cache/
public/map-data/sfx-pak-extract/
public/map-data/sfx-extracted/

# === Large binary game assets (must be hosted elsewhere or via LFS) ===
public/map-data/arena-assets/
public/map-data/terrain-textures/

# === Backups ===
*.bak
*.bak2
