# Dependencies
node_modules/

# Source mesh files (binary game assets, large)
source-meshes/

# Map data (generated, large binary files)
public/map-data/textures/
# heightmap .bin files ARE committed (64 MB, needed for terrain)
public/map-data/meshes/*.glb
# entities/*.json, entity-index.json, mesh-map.json, mesh-list.json ARE committed

# Runtime browser libs (generated by npm script, not committed)
public/lib/

# Python
__pycache__/
*.pyc

# OS
Thumbs.db
.DS_Store

# IDE
.vscode/
